# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (تأكد إن MongoDB شغالة عندك على الجهاز)
MONGO_URI=mongodb://127.0.0.1:27017/bonicare
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/bonicare_test

# Redis (لو مش مسطب ريديس سيبها زي ما هي بس البرنامج ممكن يدي إنذار)
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# JWT (مفاتيح تشفير عشوائية - لازم تكون 32 حرف أو أكتر)
JWT_SECRET=super_secret_key_12345678901234567890123456789012
JWT_REFRESH_SECRET=another_super_secret_key_abcdefghijklmnopqrstuvwxyz123456
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 2FA
TOTP_ISSUER=BoniCare
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_PERIOD=30

# Email Configuration (بيانات وهمية للتجربة)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_user_id
SMTP_PASS=your_password
FROM_EMAIL=noreply@bonicare.com
FROM_NAME=BoniCare Platform

# File Storage
STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_BUCKET=bonicare-files
S3_ENDPOINT=https://s3.amazonaws.com

# Encryption (لازم 32 حرف)
ENCRYPTION_KEY=12345678901234567890123456789012
ENCRYPTION_ALGORITHM=aes-256-gcm
SESSION_SECRET=abcdefghijklmnopqrstuvwxyz1234567890abcdef

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=test
AI_MODEL_VERSION=v1.0.0

# Backup
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=abcdefghijklmnopqrstuvwxyz1234567890abcd

