############################################
# Server Configuration
############################################
NODE_ENV=development
PORT=3000
API_VERSION=v1

############################################
# Database Configuration
# Choose ONE based on your environment:
# - Local Node.js: 127.0.0.1
# - Docker: mongo (Docker service name)
############################################

# LOCAL DEVELOPMENT (Node running on your machine)
MONGO_URI=mongodb://127.0.0.1:27017/bonicare

# DOCKER DEVELOPMENT (Node running inside container)
# MONGO_URI=mongodb://mongo:27017/bonicare

MONGODB_TEST_URI=mongodb://127.0.0.1:27017/bonicare_test

############################################
# Redis Configuration
############################################
# LOCAL
REDIS_URL=redis://127.0.0.1:6379

# DOCKER (if Redis service is added)
# REDIS_URL=redis://redis:6379

REDIS_PASSWORD=

############################################
# JWT Authentication
############################################
JWT_SECRET=replace_with_secure_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_secure_random_string_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

############################################
# 2FA Configuration
############################################
TOTP_ISSUER=BoniCare
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_PERIOD=30

############################################
# Email Configuration (Development Only)
############################################
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
FROM_EMAIL=noreply@bonicare.com
FROM_NAME=BoniCare Platform

############################################
# File Storage Configuration
############################################
STORAGE_TYPE=local
# STORAGE_TYPE=s3

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_BUCKET=bonicare-files
S3_ENDPOINT=https://s3.amazonaws.com

############################################
# Encryption
############################################
ENCRYPTION_KEY=replace_with_32_characters_minimum_key_here
ENCRYPTION_ALGORITHM=aes-256-gcm
SESSION_SECRET=replace_with_strong_session_secret

############################################
# Security
############################################
BCRYPT_ROUNDS=12

# CORS (Frontend URLs)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

############################################
# AI Service (Optional Microservice)
############################################
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=test
AI_MODEL_VERSION=v1.0.0

############################################
# Firebase Configuration (Notifications)
############################################
FIREBASE_SERVICE_ACCOUNT_PATH=../../src/config/bonicare-notifications-sys-firebase-adminsdk-fbsvc-71583c7a6d.json

############################################
# Stripe Payment Configuration
############################################
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
PAYMENT_CURRENCY=usd

############################################
# Backup Configuration (Future Production Use)
############################################
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=replace_with_secure_backup_key
